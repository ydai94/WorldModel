{
    "game_name": "Cyberpunk2077",
    "duration_sec": 600,
    "output_dir": "outputs",

    "enable_random_movement": true,
    "min_move_duration_sec": 0.5,
    "max_move_duration_sec": 3.0,
    "idle_probability": 0.1,

    "enable_camera_scan": true,
    "scan_after_every_move": true,
    "scan_candidates": ["right_90", "left_90", "look_up", "look_down", "hold"],
    "scan_weights": [0.20, 0.20, 0.20, 0.20, 0.20],
    "scan_duration_sec": 2.0,
    "scan_hold_duration_sec": 1.5,
    "mouse_sensitivity": 10.0,
    "mouse_sensitivity_y": 10.0,

    "hotkey_stop": "F8",
    "hotkey_pause": "F9",
    "countdown_sec": 5
}
